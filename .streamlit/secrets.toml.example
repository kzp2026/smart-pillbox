# Copy these values into Streamlit Cloud Secrets.
# Do not rename this file to secrets.toml with real keys before committing.

# Required for cloud-safe persistent comment knowledge storage.
PRODUCT_KB_DATABASE_URL = "postgresql://user:password@host:5432/postgres"

# Optional text generation enhancement.
DEEPSEEK_API_KEY = "sk-your-deepseek-key"
DEEPSEEK_BASE_URL = "https://api.deepseek.com"
DEEPSEEK_MODEL = "deepseek-v4-flash"

# Optional realistic rendering provider entry point reserved for Aliyun Bailian DashScope.
DASHSCOPE_API_KEY = "your-dashscope-key"
IMAGE_PROVIDER = "dashscope"
IMAGE_MODEL = "qwen-image-2.0-pro-2026-06-22"
